# ThermalSense AI — environment variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Google Earth Engine project ID
# Get from: https://console.cloud.google.com
EE_PROJECT_ID=thermalsense
GOOGLE_APPLICATION_CREDENTIALS=D:\ISROPS1\data-pipeline\gee-key.json

# Google Cloud Storage bucket name (optional for local runs)
GCS_BUCKET=thermalsense-data

# MOSDAC credentials
MOSDAC_USERNAME=your_mosdac_username
MOSDAC_PASSWORD=your_mosdac_password

# Supabase (Person C sets these up — Person A only needs for final export)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
